<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>How To Beat The Man</title>
<link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&family=Orbitron:wght@700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #ff4db8;
    --blue: #4db8ff;
    --light-blue: #a8d8ff;
    --hot-pink: #ff2d9b;
    --soft-blue: #7ec8e3;
    --white: #ffffff;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    min-height: 100vh;
    overflow-x: hidden;
    font-family: 'Orbitron', sans-serif;
    cursor: default;
  }

  /* ── BACKGROUND ── */
  .bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-color: #0a0015;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    transition: background-image 0.4s ease;
  }

  .bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(80, 160, 255, 0.35) 0%,
      rgba(180, 100, 220, 0.25) 50%,
      rgba(255, 80, 150, 0.35) 100%
    );
  }

  .bg::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 3px,
      rgba(0,0,0,0.06) 3px,
      rgba(0,0,0,0.06) 4px
    );
    pointer-events: none;
  }

  /* ── MAIN LAYOUT ── */
  .page {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 24px 60px;
  }

  /* ── HEADER LOGO BLOCK ── */
  .header {
    text-align: center;
    margin-bottom: 56px;
    animation: fadeDown 0.9s ease both;
  }

  /* Header image mode */
  .header-img {
    display: none;
    max-width: min(600px, 90vw);
    height: auto;
    filter: drop-shadow(0 0 20px rgba(255,80,180,0.6)) drop-shadow(0 0 40px rgba(100,180,255,0.4));
    margin-bottom: 12px;
  }
  .header-img.visible { display: block; margin: 0 auto 12px; }

  /* Text fallback mode */
  .header-text { display: block; }
  .header-text.hidden { display: none; }

  .title-script {
    font-family: 'Permanent Marker', cursive;
    font-size: clamp(36px, 7vw, 80px);
    color: var(--hot-pink);
    letter-spacing: 2px;
    line-height: 1.1;
    text-shadow:
      -2px -2px 0 #fff,
       2px -2px 0 #fff,
      -2px  2px 0 #fff,
       2px  2px 0 #fff,
       0 0 20px rgba(255,80,180,0.9),
       0 0 50px rgba(255,80,180,0.5);
    transform: rotate(-2deg);
    display: inline-block;
    margin-bottom: 4px;
  }

  .title-block {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(44px, 9vw, 108px);
    font-weight: 900;
    color: transparent;
    letter-spacing: 6px;
    line-height: 1;
    display: block;
    -webkit-text-stroke: 3px var(--light-blue);
    text-shadow:
       0 0 10px rgba(120,200,255,1),
       0 0 25px rgba(120,200,255,0.9),
       0 0 60px rgba(100,180,255,0.7),
       0 0 4px rgba(255,255,255,0.8);
    filter: drop-shadow(0 4px 12px rgba(0,100,200,0.5));
    margin-top: 2px;
  }

  .title-tagline {
    font-family: 'Share Tech Mono', monospace;
    font-size: clamp(9px, 1.5vw, 13px);
    color: rgba(255,255,255,0.7);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-top: 16px;
    text-shadow: 0 0 10px rgba(255,255,255,0.4);
  }

  /* ── ARCADE BUTTONS ── */
  .buttons {
    display: flex;
    flex-direction: column;
    gap: 18px;
    width: 100%;
    max-width: 420px;
    animation: fadeUp 0.9s ease 0.3s both;
  }

  .arcade-btn {
    position: relative;
    display: block;
    width: 100%;
    padding: 18px 24px;
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    font-size: clamp(13px, 2.5vw, 17px);
    letter-spacing: 5px;
    color: #fff;
    text-align: center;
    text-transform: uppercase;
    transition: transform 0.15s, filter 0.15s;
    outline: none;
  }

  .arcade-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.06);
    transition: box-shadow 0.2s, background 0.2s;
  }
  .arcade-btn::after {
    content: '';
    position: absolute;
    inset: 4px;
    border: 1px solid rgba(255,255,255,0.2);
    pointer-events: none;
  }

  .arcade-btn:hover { transform: translateY(-3px) scale(1.02); filter: brightness(1.15); }
  .arcade-btn:hover::before { background: rgba(255,255,255,0.12); }
  .arcade-btn:active { transform: translateY(1px) scale(0.99); filter: brightness(0.9); }

  .btn-articles::before  { border: 2px solid #ff9de0; box-shadow: 0 0 12px 2px #ff4db8, 0 0 30px 4px #ff4db8, inset 0 0 14px rgba(255,77,184,0.08); }
  .btn-arcade::before    { border: 2px solid #9eeeff; box-shadow: 0 0 12px 2px #00d4ff, 0 0 30px 4px #00d4ff, inset 0 0 14px rgba(0,212,255,0.08); }
  .btn-about::before     { border: 2px solid #d4b0ff; box-shadow: 0 0 12px 2px #b07eff, 0 0 30px 4px #b07eff, inset 0 0 14px rgba(176,126,255,0.08); }

  .btn-articles:hover::before { box-shadow: 0 0 20px 4px #ff4db8, 0 0 60px 10px #ff4db8, inset 0 0 20px rgba(255,77,184,0.12); }
  .btn-arcade:hover::before   { box-shadow: 0 0 20px 4px #00d4ff, 0 0 60px 10px #00d4ff, inset 0 0 20px rgba(0,212,255,0.12); }
  .btn-about:hover::before    { box-shadow: 0 0 20px 4px #b07eff, 0 0 60px 10px #b07eff, inset 0 0 20px rgba(176,126,255,0.12); }

  .btn-label { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; gap: 12px; }
  .btn-icon  { font-size: 18px; line-height: 1; }

  .btn-articles .btn-label { text-shadow: 0 0 12px #ff4db8, 0 0 30px rgba(255,77,184,0.6); }
  .btn-arcade   .btn-label { text-shadow: 0 0 12px #00d4ff, 0 0 30px rgba(0,212,255,0.6); }
  .btn-about    .btn-label { text-shadow: 0 0 12px #b07eff, 0 0 30px rgba(176,126,255,0.6); }

  /* ── FOOTER ── */
  .footer {
    position: fixed;
    bottom: 20px;
    left: 0; right: 0;
    text-align: center;
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 3px;
    z-index: 10;
  }

  /* ── EDIT TOGGLE BUTTON ── */
  .edit-toggle {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 200;
    background: rgba(0,0,0,0.6);
    border: 1px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.7);
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    letter-spacing: 2px;
    padding: 8px 14px;
    cursor: pointer;
    transition: all 0.2s;
    backdrop-filter: blur(6px);
  }
  .edit-toggle:hover { border-color: #00d4ff; color: #00d4ff; box-shadow: 0 0 10px rgba(0,212,255,0.3); }

  /* ── ADMIN PANEL ── */
  .admin-panel {
    position: fixed;
    top: 0; right: 0;
    width: min(340px, 100vw);
    height: 100vh;
    background: rgba(5, 2, 18, 0.97);
    border-left: 1px solid rgba(123,47,255,0.5);
    box-shadow: -10px 0 40px rgba(0,0,0,0.6);
    backdrop-filter: blur(12px);
    z-index: 190;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
    overflow-y: auto;
  }
  .admin-panel.open { transform: translateX(0); }

  .admin-header {
    padding: 20px 20px 14px;
    border-bottom: 1px solid rgba(123,47,255,0.3);
    background: rgba(123,47,255,0.08);
  }
  .admin-header h2 {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: #00d4ff;
    text-shadow: 0 0 8px rgba(0,212,255,0.6);
    letter-spacing: 3px;
    text-transform: uppercase;
  }
  .admin-header p {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
    margin-top: 5px;
    line-height: 1.5;
  }

  .admin-body { padding: 20px; display: flex; flex-direction: column; gap: 28px; }

  .admin-section-title {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: #ff4db8;
    text-shadow: 0 0 6px rgba(255,77,184,0.5);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid rgba(255,77,184,0.2);
  }

  .upload-zone {
    border: 1px dashed rgba(255,255,255,0.25);
    padding: 20px 16px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    background: rgba(255,255,255,0.03);
  }
  .upload-zone:hover { border-color: #00d4ff; background: rgba(0,212,255,0.05); }
  .upload-zone:hover .upload-icon { color: #00d4ff; }

  .upload-zone input[type="file"] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .upload-icon {
    font-size: 28px;
    display: block;
    margin-bottom: 8px;
    color: rgba(255,255,255,0.4);
    transition: color 0.2s;
  }

  .upload-text {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: rgba(255,255,255,0.5);
    letter-spacing: 1px;
    line-height: 1.6;
  }
  .upload-text strong { color: rgba(255,255,255,0.8); display: block; margin-bottom: 3px; }

  /* Preview thumbnail */
  .preview-wrap {
    margin-top: 10px;
    display: none;
    position: relative;
  }
  .preview-wrap.show { display: block; }
  .preview-thumb {
    width: 100%;
    height: 80px;
    object-fit: cover;
    border: 1px solid rgba(0,212,255,0.3);
    display: block;
  }
  .preview-clear {
    position: absolute;
    top: 4px; right: 4px;
    background: rgba(0,0,0,0.7);
    border: 1px solid rgba(255,77,184,0.5);
    color: #ff4db8;
    font-size: 10px;
    padding: 2px 7px;
    cursor: pointer;
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 1px;
    transition: background 0.15s;
  }
  .preview-clear:hover { background: rgba(255,77,184,0.2); }

  .preview-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    color: #00ff88;
    letter-spacing: 1px;
    margin-top: 6px;
    text-shadow: 0 0 6px rgba(0,255,136,0.4);
  }

  /* ── ANIMATIONS ── */
  @keyframes fadeDown { from { opacity:0; transform:translateY(-30px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeUp   { from { opacity:0; transform:translateY(30px);  } to { opacity:1; transform:translateY(0); } }

  .sparks { position:fixed; inset:0; pointer-events:none; z-index:5; overflow:hidden; }
  .spark  { position:absolute; width:2px; height:2px; border-radius:50%; background:#fff; opacity:0; animation:sparkFloat linear infinite; }
  @keyframes sparkFloat {
    0%   { opacity:0; transform:translateY(100vh) scale(0); }
    10%  { opacity:0.8; }
    90%  { opacity:0.4; }
    100% { opacity:0; transform:translateY(-10vh) scale(1.5); }
  }
</style>
</head>
<body>

<div class="bg" id="bg"></div>
<div class="sparks" id="sparks"></div>

<!-- Edit toggle -->
<button class="edit-toggle" onclick="toggleAdmin()">⚙ EDIT IMAGES</button>

<!-- Admin panel -->
<div class="admin-panel" id="adminPanel">
  <div class="admin-header">
    <h2>// IMAGE SETTINGS //</h2>
    <p>Upload images from your device. Changes apply instantly and persist while the page is open.</p>
  </div>

  <div class="admin-body">

    <!-- Background Image -->
    <div>
      <div class="admin-section-title">Background Image</div>
      <div class="upload-zone" id="bgZone">
        <input type="file" accept="image/*" id="bgInput" onchange="handleBgUpload(event)">
        <span class="upload-icon">🏙️</span>
        <div class="upload-text">
          <strong>Click to choose image</strong>
          JPG, PNG, WEBP supported<br>Recommended: wide landscape
        </div>
      </div>
      <div class="preview-wrap" id="bgPreviewWrap">
        <img class="preview-thumb" id="bgPreview" src="" alt="bg preview">
        <button class="preview-clear" onclick="clearBg()">✕ CLEAR</button>
        <div class="preview-label">✓ BACKGROUND APPLIED</div>
      </div>
    </div>

    <!-- Header Image -->
    <div>
      <div class="admin-section-title">Header / Logo Image</div>
      <div class="upload-zone" id="headerZone">
        <input type="file" accept="image/*" id="headerInput" onchange="handleHeaderUpload(event)">
        <span class="upload-icon">🖼️</span>
        <div class="upload-text">
          <strong>Click to choose image</strong>
          PNG with transparency recommended<br>Replaces the text title
        </div>
      </div>
      <div class="preview-wrap" id="headerPreviewWrap">
        <img class="preview-thumb" id="headerPreview" src="" alt="header preview" style="object-fit:contain; background:#000;">
        <button class="preview-clear" onclick="clearHeader()">✕ CLEAR</button>
        <div class="preview-label">✓ HEADER IMAGE APPLIED</div>
      </div>
    </div>

  </div>
</div>

<!-- Main content -->
<div class="page">
  <header class="header">
    <!-- Header image (shown when uploaded) -->
    <img class="header-img" id="headerImg" src="" alt="How To Beat The Man">

    <!-- Text fallback (shown when no image uploaded) -->
    <div class="header-text" id="headerText">
      <div class="title-script">how to beat</div>
      <span class="title-block">THE MAN</span>
    </div>

    <div class="title-tagline">financial education for the rest of us</div>
  </header>

  <nav class="buttons">
    <a href="/articles" class="arcade-btn btn-articles">
      <span class="btn-label"><span class="btn-icon">📰</span>ARTICLES</span>
    </a>
    <a href="/financial-calculator.html" class="arcade-btn btn-arcade">
      <span class="btn-label"><span class="btn-icon">🕹️</span>FINANCE ARCADE</span>
    </a>
    <a href="/about" class="arcade-btn btn-about">
      <span class="btn-label"><span class="btn-icon">👤</span>ABOUT ME</span>
    </a>
  </nav>
</div>

<div class="footer">© HOW TO BEAT THE MAN &nbsp;·&nbsp; INSERT COIN TO CONTINUE</div>

<script>
  /* ── ADMIN PANEL TOGGLE ── */
  function toggleAdmin() {
    document.getElementById('adminPanel').classList.toggle('open');
  }

  /* ── BACKGROUND IMAGE ── */
  function handleBgUpload(e) {
    const file = e.target.files[0];
    if (!file) return;
    const url = URL.createObjectURL(file);
    const bg = document.getElementById('bg');
    bg.style.backgroundImage = `url('${url}')`;

    // Preview
    document.getElementById('bgPreview').src = url;
    document.getElementById('bgPreviewWrap').classList.add('show');
  }

  function clearBg() {
    document.getElementById('bg').style.backgroundImage = '';
    document.getElementById('bgPreview').src = '';
    document.getElementById('bgPreviewWrap').classList.remove('show');
    document.getElementById('bgInput').value = '';
  }

  /* ── HEADER IMAGE ── */
  function handleHeaderUpload(e) {
    const file = e.target.files[0];
    if (!file) return;
    const url = URL.createObjectURL(file);

    // Show the image, hide text
    const img = document.getElementById('headerImg');
    img.src = url;
    img.classList.add('visible');
    document.getElementById('headerText').classList.add('hidden');

    // Preview
    document.getElementById('headerPreview').src = url;
    document.getElementById('headerPreviewWrap').classList.add('show');
  }

  function clearHeader() {
    document.getElementById('headerImg').src = '';
    document.getElementById('headerImg').classList.remove('visible');
    document.getElementById('headerText').classList.remove('hidden');
    document.getElementById('headerPreview').src = '';
    document.getElementById('headerPreviewWrap').classList.remove('show');
    document.getElementById('headerInput').value = '';
  }

  /* ── SPARKLES ── */
  const sparksEl = document.getElementById('sparks');
  const colors = ['#ff4db8','#00d4ff','#ffffff','#b07eff','#ffaadd'];
  for (let i = 0; i < 40; i++) {
    const s = document.createElement('div');
    s.className = 'spark';
    s.style.left             = Math.random() * 100 + 'vw';
    s.style.width            = (Math.random() * 3 + 1) + 'px';
    s.style.height           = s.style.width;
    s.style.background       = colors[Math.floor(Math.random() * colors.length)];
    s.style.animationDuration = (Math.random() * 12 + 8) + 's';
    s.style.animationDelay   = (Math.random() * 10) + 's';
    s.style.boxShadow        = `0 0 4px 1px ${colors[Math.floor(Math.random() * colors.length)]}`;
    sparksEl.appendChild(s);
  }
</script>
</body>
</html>
